            ],
            "properties": {
                "bucketName": {
                    "type": "string"
                },
                "fileName": {
                    "type": "string"
                }
            }
        },
        "github_com_Lomank123_go-integration-minio_pkg_client_dto.FileURLV1ResponseDTO": {
            "type": "object",
            "properties": {
                "url": {
                    "type": "string"
                }
            }
        },
        "github_com_Lomank123_go-integration-minio_pkg_client_dto.FileUploadV1ResponseDTO": {
            "type": "object",
